@{
    ViewData["Title"] = "Головна";
}

<div class="text-center mt-5">
    <h1 class="display-4 mb-4">💻 Система обліку обладнання</h1>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="alert alert-success d-inline-block px-5 shadow-sm border-0" style="border-radius: 15px;">
            <h4 class="mb-0 text-success">Вітаємо, @User.Identity.Name!</h4>
            <small class="text-muted">Ви маєте доступ до системи</small>
        </div>

        <div class="mt-5">
            <div class="d-flex justify-content-center gap-3">
                <a href="/list" class="btn btn-primary btn-lg d-flex align-items-center px-4 shadow-sm">
                    <span class="me-2">📋</span> Список обладнання
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Account" asp-action="Users" class="btn btn-dark btn-lg d-flex align-items-center px-4 shadow-sm">
                        <span class="me-2">👥</span> Керування користувачами
                    </a>
                }

                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-lg d-flex align-items-center px-4">
                    <span class="me-2">🚪</span> Вийти
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm d-inline-block p-5 mt-4" style="border-radius: 20px;">
            <p class="lead mb-4">Сесія завершена або ви ще не увійшли.</p>
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5 shadow">
                🔐 Увійти в систему
            </a>
        </div>
    }
</div>