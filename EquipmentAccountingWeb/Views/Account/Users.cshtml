@model IEnumerable<EquipmentAccountingWeb.Models.User>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
    <h4 class="mb-0">👥 Управління доступом</h4>
    <div>
        <a asp-action="CreateUser" class="btn btn-sm btn-success me-2">➕ Додати користувача</a>
        <span class="badge bg-primary">Режим: Адмін</span>
    </div>
</div>
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Логін</th>
                        <th>Повне ім'я</th>
                        <th>Поточна роль</th>
                        <th class="text-center">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@user.Login</strong></td>
                            <td>@user.FullName</td>
                            <td>
                               
                            <td class="text-center">
                                @* Якщо це сам адмін, краще не давати йому випадково змінити свою ж роль *@
                                @if (user.Login != User.FindFirst("Login")?.Value)
                                {
                                    <a asp-action="EditUser" asp-route-login="@user.Login" class="btn btn-sm btn-outline-primary">✏️ Редагувати</a>
                                }
                                else
                                {
                                    <span class="text-muted small">Це ви</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="mt-3">
                <a href="/home" class="btn btn-secondary">⬅ Назад на головну</a>
            </div>
        </div>
    </div>
</div>